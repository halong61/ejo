# Raspberry Pi 엣지 서버 환경 변수
# 이 파일을 복사해 .env 로 이름을 바꾸고 실제 값으로 채우세요.
# .env 는 .gitignore 에 포함되어 있어 git 에 커밋되지 않습니다.

# IP 카메라 RTSP 주소 (Tapo C200 기준: rtsp://아이디:비밀번호@카메라IP:554/stream1)
RTSP_URL=rtsp://username:password@192.168.x.x:554/stream1

# 백엔드 API 주소
IOT_BACKEND_BASE_URL=http://localhost:8080

# MQTT 브로커 (기본값: localhost — Raspberry Pi 자체 Mosquitto)
MQTT_BROKER=localhost
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=

# IoT 어드민 HTTP 서버 포트
IOT_ADMIN_PORT=8090

# IoT API Key (백엔드와 동일한 값으로 설정)
IOT_API_KEY=your_iot_api_key

# AWS S3 (분실물 이미지 업로드)
AWS_ACCESS_KEY=your_aws_access_key_id
AWS_SECRET_KEY=your_aws_secret_access_key
AWS_S3_BUCKET=your_s3_bucket_name
